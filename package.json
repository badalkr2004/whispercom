{
  "name": "whispercom",
  "version": "1.0.0",
  "description": "Professional AI-powered git CLI — commit messages, history browser, commit graph, file staging, branch switcher",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "whis": "dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build",
    "dev": "node build.mjs --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.18",
    "@ai-sdk/groq": "^1.2.9",
    "@ai-sdk/mistral": "^1.2.8",
    "@ai-sdk/openai": "^1.3.22",
    "ai": "^4.3.16",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "ink",
    "conventional-commits",
    "tui"
  ],
  "author": "badalkr2004",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badalkr2004/whispercom.git"
  },
  "homepage": "https://github.com/badalkr2004/whispercom#readme",
  "bugs": {
    "url": "https://github.com/badalkr2004/whispercom/issues"
  }
}
