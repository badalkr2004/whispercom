{
  "name": "commit-ai",
  "version": "3.0.0",
  "description": "Professional AI-powered git CLI — commit messages, history browser, commit graph, file staging, branch switcher",
  "type": "module",
  "bin": {
    "commit-ai": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js"
  },
  "dependencies": {
    "ai": "^4.3.16",
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.22",
    "@ai-sdk/google": "^1.2.18",
    "@ai-sdk/mistral": "^1.2.8",
    "@ai-sdk/groq": "^1.2.9",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "ink",
    "conventional-commits",
    "tui"
